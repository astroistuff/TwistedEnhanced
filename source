-- APPLY THEME
-- ================================================
local function applyTheme(idx)
    currentTheme = idx
    local t = themes[idx]

    window.BackgroundColor3 = t.bg
    winStroke.Color = t.div
    titleBar.BackgroundColor3 = t.title
    accentLine.BackgroundColor3 = t.accent
    titleTxt.TextColor3 = t.text
    minBtn.BackgroundColor3 = t.sub
    minBtn.TextColor3 = t.dim
    tabBar.BackgroundColor3 = t.title

    for name, tb in pairs(tabBtns) do
        tb.BackgroundColor3 = t.title
        tb.TextColor3 = name == activeTab and t.text or t.dim
        tb:FindFirstChild("Indicator").BackgroundColor3 = t.accent
        tb:FindFirstChild("Indicator").Visible = name == activeTab
    end

    statusLabel.TextColor3 = t.dim
    speedValue.TextColor3 = t.text
    boostBtn.BackgroundColor3 = t.btn
    boostBtn.TextColor3 = t.btnText
    stopBtn.BackgroundColor3 = t.sub
    stopBtn.TextColor3 = t.text
    stopStroke.Color = t.div
    vFlyBtn.BackgroundColor3 = t.sub
    vFlyBtn.TextColor3 = t.text
    vFlyStroke.Color = t.div
    vSliderLabel.TextColor3 = t.dim
    vSliderVal.TextColor3 = t.dim
    vSliderTrack.BackgroundColor3 = t.sub
    vSliderFill.BackgroundColor3 = t.accent
    vSliderKnob.BackgroundColor3 = t.text
    dayBtn.BackgroundColor3 = forceDay and t.accent or t.sub
    dayBtn.TextColor3 = forceDay and t.btnText or t.text
    dayStroke.Color = t.div
    pFlyBtn.BackgroundColor3 = t.sub
    pFlyBtn.TextColor3 = t.text
    pFlyStroke.Color = t.div
    pSliderLabel.TextColor3 = t.dim
    pSliderVal.TextColor3 = t.dim
    pSliderTrack.BackgroundColor3 = t.sub
    pSliderFill.BackgroundColor3 = t.accent
    pSliderKnob.BackgroundColor3 = t.text
    pFlyHint.TextColor3 = t.dim
    antiPickupBtn.BackgroundColor3 = antiPickup and t.accent or t.sub
    antiPickupBtn.TextColor3 = antiPickup and t.btnText or t.text
    antiPickupStroke.Color = t.div
    antiPickupHint.TextColor3 = t.dim

    for i2, data in ipairs(themeButtons) do
        data.stroke.Color = i2 == idx and t.accent or themes[i2].div
        data.stroke.Thickness = i2 == idx and 2 or 1
    end
end

for i, data in ipairs(themeButtons) do
    data.btn.MouseButton1Click:Connect(function()
        applyTheme(i)
    end)
end

