local function enablePlayerFly()
    local character = player.Character
    if not character then return end
    local hrp = character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    playerFlyOn = true

    playerFlyPart = Instance.new("Part")
    playerFlyPart.Name = "PlayerFlyPart"
    playerFlyPart.Size = Vector3.new(1, 1, 1)
    playerFlyPart.Transparency = 1
    playerFlyPart.CanCollide = false
    playerFlyPart.Anchored = false
    playerFlyPart.CFrame = hrp.CFrame
    playerFlyPart.Parent = workspace

    local weld = Instance.new("WeldConstraint")
    weld.Name = "PlayerFlyWeld"
    weld.Part0 = playerFlyPart
    weld.Part1 = hrp
    weld.Parent = playerFlyPart

    local bg = Instance.new("BodyGyro")
    bg.Name = "FlyGyro"
    bg.MaxTorque = Vector3.new(4e5, 4e5, 4e5)
    bg.D = 100
    bg.CFrame = hrp.CFrame
    bg.Parent = playerFlyPart

    local bv = Instance.new("BodyVelocity")
    bv.Name = "FlyVelocity"
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = playerFlyPart

    local hum = character:FindFirstChildOfClass("Humanoid")
    if hum then hum.PlatformStand = true end

    pFlyBtn.Text = "PLAYER FLY: ON"
    pFlyBtn.BackgroundColor3 = themes[currentTheme].accent
    pFlyBtn.TextColor3 = themes[currentTheme].btnText
end

local function disablePlayerFly()
    playerFlyOn = false
    if playerFlyPart then
        playerFlyPart:Destroy()
        playerFlyPart = nil
    end
    local character = player.Character
    if character then
        local hum = character:FindFirstChildOfClass("Humanoid")
        if hum then hum.PlatformStand = false end
    end
    pFlyBtn.Text = "PLAYER FLY: OFF"
    pFlyBtn.BackgroundColor3 = themes[currentTheme].sub
    pFlyBtn.TextColor3 = themes[currentTheme].text
end

pFlyBtn.MouseButton1Click:Connect(function()
    if playerFlyOn then disablePlayerFly() else enablePlayerFly() end
end)

