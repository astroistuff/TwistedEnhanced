local function makeCorner(parent, r)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, r or 8)
    c.Parent = parent
end

local function makeDivider(parent, y, theme)
    local d = Instance.new("Frame")
    d.Size = UDim2.new(1, -28, 0, 1)
    d.Position = UDim2.new(0, 14, 0, y)
    d.BackgroundColor3 = themes[currentTheme].div
    d.BorderSizePixel = 0
    d.Name = "Divider"
    d.Parent = parent
    return d
end

local function makeBtn(parent, text, y, h, bg, tc)
    local b = Instance.new("TextButton")
    b.Size = UDim2.new(1, -28, 0, h or 38)
    b.Position = UDim2.new(0, 14, 0, y)
    b.BackgroundColor3 = bg or themes[currentTheme].sub
    b.TextColor3 = tc or themes[currentTheme].text
    b.Text = text
    b.Font = Enum.Font.GothamBold
    b.TextSize = 11
    b.BorderSizePixel = 0
    b.AutoButtonColor = false
    makeCorner(b, 7)
    b.Parent = parent
    return b
end

local function makeLabel(parent, text, size, x, y, w, h, color, font, xalign)
    local l = Instance.new("TextLabel")
    l.Size = UDim2.new(0, w, 0, h)
    l.Position = UDim2.new(0, x, 0, y)
    l.BackgroundTransparency = 1
    l.Text = text
    l.TextColor3 = color or themes[currentTheme].text
    l.Font = font or Enum.Font.GothamBold
    l.TextSize = size
    l.TextXAlignment = xalign or Enum.TextXAlignment.Left
    l.Parent = parent
    return l
end

