-- ================================================
-- READ SPEED FROM SPEEDOMETER UI
-- ================================================
local function getUISpeed()
    local pGui = player.PlayerGui
    local vehicleUI = pGui:FindFirstChild("vehicle_ui")
    if not vehicleUI then return nil end
    local pc = vehicleUI:FindFirstChild("pc")
    if not pc then return nil end
    local drivetrain = pc:FindFirstChild("drivetrain")
    if not drivetrain then return nil end
    local speedometer = drivetrain:FindFirstChild("speedometer")
    if not speedometer then return nil end
    local speedObj = speedometer:FindFirstChild("speed")
    if not speedObj then return nil end
    -- It might be a TextLabel or IntValue etc
    if speedObj:IsA("TextLabel") or speedObj:IsA("TextBox") then
        return speedObj.Text
    elseif speedObj:IsA("IntValue") or speedObj:IsA("NumberValue") then
        return tostring(math.floor(speedObj.Value))
    end
    return nil
end

-- ================================================
-- MAIN LOOP
-- ================================================
RunService.RenderStepped:Connect(function()
    local t = themes[currentTheme]

    -- Force day
    if forceDay then
        Lighting.ClockTime = 14
        Lighting.Brightness = 2
        Lighting.Ambient = Color3.fromRGB(120, 120, 120)
        Lighting.OutdoorAmbient = Color3.fromRGB(140, 140, 140)
    end

    -- Speed display from UI
    local uiSpeed = getUISpeed()
    if uiSpeed then
        speedValue.Text = uiSpeed .. " mph"
    elseif carRoot then
        local vel = carRoot.AssemblyLinearVelocity
        local s = math.floor(Vector3.new(vel.X, 0, vel.Z).Magnitude * 0.44)
        speedValue.Text = s .. " mph"
    end

    -- Color speed
    local numSpeed = tonumber(speedValue.Text:match("%d+")) or 0
    if numSpeed < 80 then
        speedValue.TextColor3 = t.text
    elseif numSpeed < 130 then
        speedValue.TextColor3 = Color3.fromRGB(255, 200, 60)
    else
        speedValue.TextColor3 = Color3.fromRGB(255, 70, 70)
    end

    -- Anti-Pickup: zero out upward velocity on player and car every frame
    if antiPickup then
        local character = player.Character
        if character then
            local hrp = character:FindFirstChild("HumanoidRootPart")
            if hrp then
                local v = hrp.AssemblyLinearVelocity
                if v.Y > 2 then
                    hrp.AssemblyLinearVelocity = Vector3.new(v.X, 0, v.Z)
                end
            end
        end
        if carRoot then
            local cv = carRoot.AssemblyLinearVelocity
            if cv.Y > 2 then
                carRoot.AssemblyLinearVelocity = Vector3.new(cv.X, 0, cv.Z)
            end
        end
    end
    -- Car boost
    if isBoosting and carRoot then
        local forward = carRoot.CFrame.LookVector
        local flat = Vector3.new(forward.X, 0, forward.Z).Unit
        carRoot:ApplyImpulse(flat * BOOST_FORCE)
    end

    -- Vehicle fly controls
    if vehicleFlyOn and vehicleFlyPart then
        local bv = vehicleFlyPart:FindFirstChild("FlyVelocity")
        local bg = vehicleFlyPart:FindFirstChild("FlyGyro")
        if bv and bg then
            local cam = workspace.CurrentCamera
            local vel = Vector3.new()
            local spd = vehicleFlySpeed * 80
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vel = vel - Vector3.new(0,1,0) end
            bv.Velocity = vel.Magnitude > 0 and vel.Unit * spd or Vector3.new()
            bg.CFrame = cam.CFrame
        end
    end

    -- Player fly controls
    if playerFlyOn and playerFlyPart then
        local bv = playerFlyPart:FindFirstChild("FlyVelocity")
        local bg = playerFlyPart:FindFirstChild("FlyGyro")
        if bv and bg then
            local cam = workspace.CurrentCamera
            local vel = Vector3.new()
            local spd = playerFlySpeed * 80
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then vel = vel + cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then vel = vel - cam.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then vel = vel - cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then vel = vel + cam.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then vel = vel + Vector3.new(0,1,0) end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then vel = vel - Vector3.new(0,1,0) end
            bv.Velocity = vel.Magnitude > 0 and vel.Unit * spd or Vector3.new()
            bg.CFrame = cam.CFrame
        end
    end
end)
