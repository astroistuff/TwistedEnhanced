-- ================================================
-- VEHICLE FLY
-- ================================================
local function enableVehicleFly()
    if not carRoot then return end
    vehicleFlyOn = true

    -- Create invisible fly platform under the car
    vehicleFlyPart = Instance.new("Part")
    vehicleFlyPart.Name = "VehicleFlyPart"
    vehicleFlyPart.Size = Vector3.new(4, 1, 4)
    vehicleFlyPart.Transparency = 1
    vehicleFlyPart.CanCollide = false
    vehicleFlyPart.Anchored = false
    vehicleFlyPart.CFrame = carRoot.CFrame * CFrame.new(0, -2, 0)
    vehicleFlyPart.Parent = workspace

    -- Weld fly part to car
    local weld = Instance.new("WeldConstraint")
    weld.Name = "FlyWeld"
    weld.Part0 = vehicleFlyPart
    weld.Part1 = carRoot
    weld.Parent = vehicleFlyPart

    -- Remove gravity on car assembly
    local bg = Instance.new("BodyGyro")
    bg.Name = "FlyGyro"
    bg.MaxTorque = Vector3.new(4e5, 4e5, 4e5)
    bg.D = 100
    bg.CFrame = carRoot.CFrame
    bg.Parent = vehicleFlyPart

    local bv = Instance.new("BodyVelocity")
    bv.Name = "FlyVelocity"
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(0, 0, 0)
    bv.Parent = vehicleFlyPart

    vFlyBtn.Text = "VEHICLE FLY: ON"
    vFlyBtn.BackgroundColor3 = themes[currentTheme].accent
    vFlyBtn.TextColor3 = themes[currentTheme].btnText
end

local function disableVehicleFly()
    vehicleFlyOn = false
    if vehicleFlyPart then
        vehicleFlyPart:Destroy()
        vehicleFlyPart = nil
    end
    vFlyBtn.Text = "VEHICLE FLY: OFF"
    vFlyBtn.BackgroundColor3 = themes[currentTheme].sub
    vFlyBtn.TextColor3 = themes[currentTheme].text
end

vFlyBtn.MouseButton1Click:Connect(function()
    if vehicleFlyOn then disableVehicleFly() else enableVehicleFly() end
end)

