-- FIND CAR
-- ================================================
local function tryLoadCar(cars)
    local carFolder = cars:FindFirstChild(tostring(player.UserId))
    carRoot = nil
    if not carFolder then
        statusLabel.Text = "No car found"
        return
    end
    for _, obj in ipairs(carFolder:GetChildren()) do
        if obj:IsA("BasePart") then
            carRoot = obj
            statusLabel.Text = "Car detected"
            statusLabel.TextColor3 = Color3.fromRGB(80, 200, 120)
            return
        end
    end
end

task.spawn(function()
    local pr = workspace:WaitForChild("player_related")
    local cars = pr:WaitForChild("cars")
    tryLoadCar(cars)
    cars.ChildAdded:Connect(function() task.wait(0.5) tryLoadCar(cars) end)
    cars.ChildRemoved:Connect(function() task.wait(0.1) tryLoadCar(cars) end)
end)

